# Server Configuration
PORT=4000

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Toss Payments Configuration
TOSS_SECRET_KEY=your-toss-secret-key
TOSS_SECURITY_KEY=your-toss-security-key
TOSS_PAYMENTS_SECRET_KEY=your-toss-payments-secret-key
TOSS_DEV_SECRET_KEY=your-toss-dev-secret-key
TOSS_PROD_SECRET_KEY=your-toss-prod-secret-key

# Push Notification Configuration (Web Push - Optional)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
